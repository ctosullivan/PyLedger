# =============================================================================
# PyLedger .gitignore
# =============================================================================

# ----------------------------------------------------------------------------
# Secrets & credentials — never commit these
# ----------------------------------------------------------------------------
.env
.env.*
*.env
!.env.example
secrets/
secrets.json
credentials.json
*.pem
*.key
*.p12
*.pfx
api_keys.*
config.local.*

# ----------------------------------------------------------------------------
# Python build artefacts
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
wheels/
*.whl
MANIFEST

# ----------------------------------------------------------------------------
# Virtual environments
# ----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env/
pip-selfcheck.json

# ----------------------------------------------------------------------------
# Testing & coverage
# ----------------------------------------------------------------------------
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.pytest_cache/
junit*.xml
test-results/

# ----------------------------------------------------------------------------
# Type-checking
# ----------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
.pyright/
.ruff_cache/

# ----------------------------------------------------------------------------
# IDEs & editors
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
.claude/

# ----------------------------------------------------------------------------
# Jupyter notebooks (checkpoint files)
# ----------------------------------------------------------------------------
.ipynb_checkpoints/

# ----------------------------------------------------------------------------
# Distribution / packaging
# ----------------------------------------------------------------------------
*.tar.gz
*.zip
*.rar
site/

# ----------------------------------------------------------------------------
# Logs & local data
# ----------------------------------------------------------------------------
*.log
*.sqlite
*.db
logs/

# ----------------------------------------------------------------------------
# hledger / accounting files that may contain private financial data
# ----------------------------------------------------------------------------
personal.journal
private.journal
*.private.journal
private/
